CHALLENGE_LIFETIME=300
REDIS_HOST=redis
REDIS_PORT=6379
# Password for Redis. Leave empty for a passwordless local dev instance;
# set a strong value for any real deployment.
REDIS_PASSWORD=
# Key used to sign session cookies. REQUIRED in production: without it,
# identity cookies are forgeable. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
